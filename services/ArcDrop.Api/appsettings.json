{
  "AdminCredentialPolicy": {
    "MinimumPasswordLength": 12,
    "RequireUppercase": true,
    "RequireLowercase": true,
    "RequireDigit": true,
    "RequireSpecialCharacter": true,
    "DisallowPasswordReuse": true
  },
  "Jwt": {
    "Issuer": "ArcDrop",
    "Audience": "ArcDropClients",
    "SigningKey": "ChangeThisJwtSigningKeyForSelfHostAtLeast32Chars",
    "AccessTokenLifetimeMinutes": 60
  },
  "ConnectionStrings": {
    "ArcDropPostgres": "Host=localhost;Port=5432;Database=arcdrop;Username=arcdrop;Password=ChangeThisPassword"
  },
  "Admin": {
    "Username": "admin",
    "Password": "ChangeThisPasswordInEnv"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
