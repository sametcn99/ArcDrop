# ArcDrop self-host environment template.
# Copy this file to .env in the same folder and replace all placeholder secrets.

ARCDROP_POSTGRES_DB=arcdrop
ARCDROP_POSTGRES_USER=arcdrop
ARCDROP_POSTGRES_PASSWORD=replace-with-strong-postgres-password
ARCDROP_POSTGRES_PORT=5432

ARCDROP_API_PORT=8080
ARCDROP_API_ENVIRONMENT=Production

ARCDROP_ADMIN_USERNAME=admin
ARCDROP_ADMIN_PASSWORD=replace-with-strong-admin-password

ARCDROP_ADMIN_CREDENTIAL_POLICY_MINIMUM_PASSWORD_LENGTH=12
ARCDROP_ADMIN_CREDENTIAL_POLICY_REQUIRE_UPPERCASE=true
ARCDROP_ADMIN_CREDENTIAL_POLICY_REQUIRE_LOWERCASE=true
ARCDROP_ADMIN_CREDENTIAL_POLICY_REQUIRE_DIGIT=true
ARCDROP_ADMIN_CREDENTIAL_POLICY_REQUIRE_SPECIAL_CHARACTER=true
ARCDROP_ADMIN_CREDENTIAL_POLICY_DISALLOW_PASSWORD_REUSE=true

ARCDROP_JWT_ISSUER=ArcDrop
ARCDROP_JWT_AUDIENCE=ArcDropClients
ARCDROP_JWT_SIGNING_KEY=replace-with-at-least-32-char-random-signing-key
ARCDROP_JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
