{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "windows": "powershell -NoProfile -ExecutionPolicy Bypass -File .github/hooks/scripts/session-start-context.ps1",
        "timeout": 8
      }
    ],
    "PreToolUse": [
      {
        "type": "command",
        "windows": "powershell -NoProfile -ExecutionPolicy Bypass -File .github/hooks/scripts/pre-tool-guard.ps1",
        "timeout": 12
      }
    ]
  }
}
