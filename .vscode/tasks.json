{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build ArcDrop API",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/services/ArcDrop.Api/ArcDrop.Api.csproj",
        "-c",
        "Debug"
      ],
      "group": "build",
      "problemMatcher": [
        "$msCompile"
      ]
    },
    {
      "label": "build ArcDrop Web",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/apps/web/ArcDrop.Web/ArcDrop.Web.csproj",
        "-c",
        "Debug"
      ],
      "group": "build",
      "problemMatcher": [
        "$msCompile"
      ]
    }
  ]
}
