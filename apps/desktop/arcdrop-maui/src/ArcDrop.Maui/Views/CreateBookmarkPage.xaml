<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:ArcDrop.Maui.ViewModels"
             x:Class="ArcDrop.Maui.Views.CreateBookmarkPage"
             x:DataType="viewModels:CreateBookmarkViewModel"
             Title="Add Bookmark">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12">
            <Label Text="Add Bookmark"
                   FontSize="28"
                   FontAttributes="Bold"
                   SemanticProperties.HeadingLevel="Level1" />

            <Label Text="Title" FontAttributes="Bold" />
            <Entry Text="{Binding Title}" Placeholder="Bookmark title" />

            <Label Text="URL" FontAttributes="Bold" />
            <Entry Text="{Binding Url}" Placeholder="https://example.com" />

            <Label Text="Summary" FontAttributes="Bold" />
            <Editor Text="{Binding Summary}" AutoSize="TextChanges" MinimumHeightRequest="120" />

            <Button Text="Save"
                    Command="{Binding SaveCommand}" />

            <Label Text="{Binding StatusText}"
                   FontSize="13"
                   TextColor="Gray" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
