<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:ArcDrop.Maui.ViewModels"
             x:Class="ArcDrop.Maui.Views.DashboardPage"
             x:DataType="viewModels:DashboardViewModel"
             Title="Dashboard">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">
            <Label Text="{Binding HeaderText}"
                   FontSize="30"
                   FontAttributes="Bold"
                   SemanticProperties.HeadingLevel="Level1" />

            <Label Text="{Binding SubtitleText}"
                   FontSize="16"
                   LineBreakMode="WordWrap" />

            <HorizontalStackLayout Spacing="10">
                <Button Text="Open Bookmarks"
                    Command="{Binding OpenBookmarksCommand}"
                    HorizontalOptions="Start" />

                <Button Text="Open Settings"
                        Command="{Binding OpenSettingsCommand}"
                        HorizontalOptions="Start" />
            </HorizontalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
