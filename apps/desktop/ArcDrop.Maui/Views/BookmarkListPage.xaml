<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:ArcDrop.Maui.ViewModels"
             x:Class="ArcDrop.Maui.Views.BookmarkListPage"
             x:DataType="viewModels:BookmarkListViewModel"
             Title="Bookmarks">

    <Grid Padding="20" RowDefinitions="Auto,Auto,Auto,*" RowSpacing="12">
        <Label Grid.Row="0"
               Text="Bookmarks"
               FontSize="28"
               FontAttributes="Bold"
               SemanticProperties.HeadingLevel="Level1" />

        <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="8">
            <Entry Grid.Column="0"
               Placeholder="Search by title, URL, or summary"
               Text="{Binding SearchText}" />
            <Button Grid.Column="1"
                Text="Search"
                Command="{Binding SearchCommand}" />
            <Button Grid.Column="2"
                Text="Refresh"
                Command="{Binding LoadBookmarksCommand}" />
            <Button Grid.Column="3"
                Text="Add"
                Command="{Binding OpenCreateBookmarkCommand}" />
        </Grid>

        <Label Grid.Row="2"
               Text="{Binding StatusText}"
               FontSize="13"
               TextColor="Gray" />

        <CollectionView Grid.Row="3"
                        ItemsSource="{Binding Items}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="viewModels:BookmarkListItemViewModel">
                    <Border StrokeThickness="1" Stroke="#DDD" Padding="12" Margin="0,0,0,10">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:BookmarkListViewModel}}, Path=OpenBookmarkCommand}"
                                CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>

                        <VerticalStackLayout Spacing="6">
                            <Label Text="{Binding Title}" FontSize="17" FontAttributes="Bold" />
                            <Label Text="{Binding Url}" FontSize="13" TextColor="#2A5DB0" LineBreakMode="TailTruncation" />
                            <Label Text="{Binding Summary}" FontSize="14" LineBreakMode="WordWrap" />
                            <Label Text="{Binding UpdatedAtText}" FontSize="12" TextColor="Gray" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
