@page "/"
@page "/bookmarks"

@inject IArcDropApiClient ApiClient
@inject ISharedStateService SharedStateService
@inject NavigationManager NavigationManager
@inject IHttpClientFactory HttpClientFactory
@implements IDisposable

<PageTitle>Bookmarks</PageTitle>

<div class="raindrop-header">
    <div>
        <h1>Bookmarks</h1>
        <p class="page-subtitle">Your reading queue and bookmark workspace.</p>
    </div>
</div>

<div class="raindrop-board">
    <aside class="raindrop-sidebar card-shell">
        <h2>Collections</h2>
        <button class="collection-item @(SelectedCollectionId is null && !IsOtherCollectionSelected ? "is-active" : string.Empty)" @onclick="(() => SelectCollection(null))">
            <span>All bookmarks</span>
            <strong>@_allBookmarks.Count</strong>
        </button>

        <button class="collection-item @(IsOtherCollectionSelected ? "is-active" : string.Empty)" @onclick="SelectOtherCollection">
            <span>Other</span>
            <strong>@UnassignedBookmarkCount</strong>
        </button>

        @foreach (var collection in AvailableCollections.OrderBy(collection => CollectionDepth(collection.Id)).ThenBy(collection => collection.Name))
        {
            var collectionBookmarkCount = _allBookmarks.Count(bookmark => bookmark.CollectionIds.Contains(collection.Id));
            <button class="collection-item @(SelectedCollectionId == collection.Id ? "is-active" : string.Empty)"
                    style="margin-left:@(CollectionDepth(collection.Id) * 0.7)rem;"
                    @onclick="(() => SelectCollection(collection.Id))">
                <span>@collection.Name</span>
                <strong>@collectionBookmarkCount</strong>
            </button>
        }
    </aside>

    <section>
        <div class="card-shell mb-3 raindrop-toolbar">
            <input class="form-control"
                   placeholder="Search title, URL, or summary"
                   @bind="SearchText"
                   @bind:event="oninput" />
            <button class="btn btn-primary" type="button" @onclick="OpenCreateDialog">Add Bookmark</button>
            <button class="btn btn-outline-secondary" type="button" @onclick="OpenCreateCollectionDialog">New Collection</button>
            <button class="btn btn-outline-secondary" @onclick="LoadAsync" disabled="@IsLoading">Refresh</button>
        </div>

        @if (IsLoading)
        {
            <div class="card-shell" style="padding: 2rem; text-align: center;">
                <span class="spinner-inline"></span> Loading bookmarks...
            </div>
        }
        else if (!string.IsNullOrWhiteSpace(ErrorText))
        {
            <div class="alert alert-danger" role="alert">@ErrorText</div>
        }
        else if (FilteredBookmarks.Count == 0)
        {
            <div class="empty-state">
                <div class="empty-state__icon">
                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
                </div>
                <p class="empty-state__title">No bookmarks found</p>
                <p class="empty-state__text">Try a different filter or add your first bookmark.</p>
            </div>
        }
        else
        {
            <div class="bookmark-feed">
                @foreach (var item in FilteredBookmarks)
                {
                    <article class="bookmark-card">
                        <div class="bookmark-card__heading">
                            <div class="bookmark-card__icon-shell" aria-hidden="true">
                                <img class="bookmark-card__icon"
                                     src="@BuildBookmarkIconUrl(item.Url)"
                                     alt=""
                                     width="44"
                                     height="44"
                                     onload="this.nextElementSibling.style.display='none'; this.style.display='block';"
                                     onerror="this.style.display='none'; this.nextElementSibling.style.display='inline-flex';" />
                                <span class="bookmark-card__icon-fallback">@DomainInitial(item.Url)</span>
                            </div>
                            <div class="bookmark-card__heading-copy">
                                <div class="bookmark-card__meta">
                                    <span>@item.UpdatedAtUtc.ToLocalTime().ToString("g")</span>
                                    <span class="bookmark-card__domain">@DomainFromUrl(item.Url)</span>
                                </div>
                                <h3>@item.Title</h3>
                            </div>
                        </div>
                        <a href="@item.Url" target="_blank" rel="noopener noreferrer">@item.Url</a>
                        @if (!string.IsNullOrWhiteSpace(item.Summary))
                        {
                            <p>@item.Summary</p>
                        }
                        <div class="bookmark-card__actions">
                            @* Edit action opens an in-page dialog to keep users in the board workflow. *@
                            <button class="btn btn-sm btn-outline-secondary" type="button" @onclick="(() => OpenEditDialogAsync(item))">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: -1px; margin-right: 3px;"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                                Edit
                            </button>
                        </div>
                    </article>
                }
            </div>
        }
    </section>
</div>

@if (IsEditDialogOpen)
{
    <div style="position:fixed;inset:0;background:rgba(7,18,17,0.48);z-index:1090;" @onclick="CloseEditDialog"></div>
    <section style="position:fixed;left:50%;top:50%;transform:translate(-50%, -50%);z-index:1091;width:min(560px,calc(100vw - 1.5rem));max-height:calc(100vh - 1.5rem);overflow-y:auto;background:var(--arc-surface-raised);border:1px solid var(--arc-border-light);border-radius:var(--arc-radius-lg);box-shadow:var(--arc-shadow-lg);padding:1.1rem;">
        <header style="display:flex;align-items:flex-start;justify-content:space-between;gap:0.75rem;margin-bottom:0.9rem;">
            <div>
                <h2 style="margin-bottom:0.25rem;">Edit Bookmark</h2>
                <p class="page-subtitle">Update title, URL, or summary without leaving this page.</p>
            </div>
            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="CloseEditDialog" disabled="@IsSavingEdit">Close</button>
        </header>

        <EditForm Model="EditModel" OnValidSubmit="SaveEditAsync">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="mb-3">
                <label class="form-label">Title</label>
                <InputText class="form-control" @bind-Value="EditModel.Title" @oninput="@(e => { EditModel.Title = e.Value?.ToString() ?? string.Empty; StateHasChanged(); })" />
            </div>

            <div class="mb-3">
                <label class="form-label">URL</label>
                <input class="form-control"
                       value="@EditModel.Url"
                       @oninput="HandleEditUrlInputAsync" />
                @if (IsEditMetadataLoading)
                {
                    <div class="form-text mt-1"><span class="spinner-inline"></span> Fetching page title and description...</div>
                }
                else if (!string.IsNullOrWhiteSpace(EditMetadataErrorText))
                {
                    <div class="form-text text-danger mt-1">@EditMetadataErrorText</div>
                }
                else if (EditMetadataSuggestion is not null)
                {
                    <section class="bookmark-metadata-suggestion mt-2" aria-label="URL metadata suggestion">
                        <p class="bookmark-metadata-suggestion__label">Suggested from URL</p>
                        <h3>@EditMetadataSuggestion.Title</h3>
                        @if (!string.IsNullOrWhiteSpace(EditMetadataSuggestion.Description))
                        {
                            <p>@EditMetadataSuggestion.Description</p>
                        }
                        <div class="bookmark-metadata-suggestion__actions">
                            <button class="btn btn-sm btn-outline-secondary" type="button" @onclick="ApplyEditMetadataSuggestion">Use Suggestion</button>
                            <button class="btn btn-sm btn-primary" type="button" @onclick="ApplyEditMetadataSuggestionAndSaveAsync" disabled="@IsSavingEdit">
                                @if (IsSavingEdit) { <span class="spinner-inline"></span> }
                                Use and Save
                            </button>
                        </div>
                    </section>
                }
            </div>

            <div class="mb-3">
                <label class="form-label">Summary</label>
                <InputTextArea class="form-control" @bind-Value="EditModel.Summary" rows="3" @oninput="@(e => { EditModel.Summary = e.Value?.ToString(); StateHasChanged(); })" />
            </div>

            <div class="mb-3">
                <label class="form-label">Collections</label>
                @if (AvailableCollections.Count == 0)
                {
                    <div class="form-text">No collections available yet.</div>
                }
                else
                {
                    <div style="max-height: 180px; overflow-y: auto; border: 1px solid var(--arc-border-light); border-radius: 8px; padding: 0.5rem;">
                        @foreach (var collection in AvailableCollections)
                        {
                            <label class="d-flex align-items-center gap-2" style="padding: 0.15rem 0; margin-left:@(CollectionDepth(collection.Id) * 0.7)rem;">
                                <input type="checkbox"
                                       checked="@SelectedEditCollectionIds.Contains(collection.Id)"
                                       @onchange="(args => ToggleEditCollectionSelection(collection.Id, args.Value))" />
                                <span>@collection.Name</span>
                            </label>
                        }
                    </div>
                }
            </div>

            @if (!string.IsNullOrWhiteSpace(EditErrorText))
            {
                <div class="alert alert-danger" role="alert">@EditErrorText</div>
            }

            <div style="display:flex;justify-content:flex-end;gap:0.5rem;">
                <button class="btn btn-outline-secondary" type="button" @onclick="CloseEditDialog" disabled="@IsSavingEdit">Cancel</button>
                <button class="btn btn-primary" type="submit" disabled="@IsSavingEdit">
                    @if (IsSavingEdit) { <span class="spinner-inline"></span> }
                    Save Changes
                </button>
            </div>
        </EditForm>
    </section>
}

<BookmarkCreateDialog IsOpen="IsCreateDialogOpen"
                      AvailableCollections="AvailableCollections"
                      OnCloseRequested="CloseCreateDialog"
                      OnCreated="HandleBookmarkCreatedAsync" />

<CollectionCreateDialog IsOpen="IsCreateCollectionDialogOpen"
                        AvailableCollections="AvailableCollections"
                        OnCloseRequested="CloseCreateCollectionDialog"
                        OnCreated="HandleCollectionCreatedAsync" />

@code {
    private const string OtherVirtualCollectionKey = "other";

    [Parameter]
    [SupplyParameterFromQuery(Name = "collectionId")]
    public Guid? SelectedCollectionId { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "virtualCollection")]
    public string? VirtualCollection { get; set; }

    private readonly List<BookmarkDto> _allBookmarks = [];
    private List<BookmarkDto> FilteredBookmarks { get; set; } = [];

    private bool IsLoading { get; set; }
    private string? ErrorText { get; set; }
    private string StatusText { get; set; } = "Ready.";

    private bool IsCreateDialogOpen { get; set; }
    private bool IsCreateCollectionDialogOpen { get; set; }
    private bool IsEditDialogOpen { get; set; }
    private bool IsSavingEdit { get; set; }
    private string? EditErrorText { get; set; }
    private Guid? EditingBookmarkId { get; set; }
    private UpdateBookmarkRequest EditModel { get; set; } = new();
    private UpdateBookmarkRequest OriginalEditModel { get; set; } = new();
    private bool IsEditMetadataLoading { get; set; }
    private string? EditMetadataErrorText { get; set; }
    private BookmarkMetadataSuggestion? EditMetadataSuggestion { get; set; }
    private CancellationTokenSource? EditMetadataLookupCts { get; set; }
    private string LastEditMetadataLookupUrl { get; set; } = string.Empty;
    private IReadOnlyList<CollectionDto> AvailableCollections { get; set; } = [];
    private HashSet<Guid> SelectedEditCollectionIds { get; set; } = [];

    private bool HasEditChanges
    {
        get
        {
            if (EditingBookmarkId is null) return false;
            
            var titleChanged = !string.Equals(EditModel.Title?.Trim(), OriginalEditModel.Title?.Trim(), StringComparison.Ordinal);
            var urlChanged = !string.Equals(EditModel.Url?.Trim(), OriginalEditModel.Url?.Trim(), StringComparison.Ordinal);
            var summaryChanged = !string.Equals(EditModel.Summary?.Trim() ?? "", OriginalEditModel.Summary?.Trim() ?? "", StringComparison.Ordinal);
            
            return titleChanged || urlChanged || summaryChanged;
        }
    }

    private string _searchText = string.Empty;

    private string SearchText
    {
        get => _searchText;
        set
        {
            _searchText = value;
            ApplyFilter();
        }
    }

    private bool IsOtherCollectionSelected => string.Equals(VirtualCollection, OtherVirtualCollectionKey, StringComparison.OrdinalIgnoreCase);

    private int UnassignedBookmarkCount => _allBookmarks.Count(bookmark => bookmark.CollectionIds.Count == 0);

    protected override async Task OnInitializedAsync()
    {
        SharedStateService.OnBookmarksUpdated += HandleBookmarksUpdated;
        SharedStateService.OnCollectionsUpdated += HandleCollectionsUpdated;
        await LoadCollectionsAsync();
        await LoadAsync();
    }

    protected override void OnParametersSet()
    {
        ApplyFilter();
    }

    private async void HandleBookmarksUpdated()
    {
        await InvokeAsync(async () =>
        {
            await LoadAsync();
            StateHasChanged();
        });
    }

    private async void HandleCollectionsUpdated()
    {
        await InvokeAsync(async () =>
        {
            await LoadCollectionsAsync();
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        SharedStateService.OnBookmarksUpdated -= HandleBookmarksUpdated;
        SharedStateService.OnCollectionsUpdated -= HandleCollectionsUpdated;
        EditMetadataLookupCts?.Cancel();
        EditMetadataLookupCts?.Dispose();
    }

    private async Task LoadCollectionsAsync()
    {
        try
        {
            AvailableCollections = await ApiClient.GetCollectionsAsync(CancellationToken.None);
        }
        catch
        {
            AvailableCollections = [];
        }
    }

    private void OpenCreateDialog()
    {
        IsCreateDialogOpen = true;
    }

    private Task CloseCreateDialog()
    {
        IsCreateDialogOpen = false;
        return Task.CompletedTask;
    }

    private void OpenCreateCollectionDialog()
    {
        IsCreateCollectionDialogOpen = true;
    }

    private Task CloseCreateCollectionDialog()
    {
        IsCreateCollectionDialogOpen = false;
        return Task.CompletedTask;
    }

    private async Task HandleBookmarkCreatedAsync()
    {
        // New bookmark events update board counts and ordering immediately.
        await LoadAsync();
        StateHasChanged();
    }

    private async Task HandleCollectionCreatedAsync()
    {
        // New collection events refresh sidebar tree and collection dropdowns.
        await LoadCollectionsAsync();
        StateHasChanged();
    }

    private async Task LoadAsync()
    {
        IsLoading = true;
        ErrorText = null;
        StatusText = "Loading bookmarks...";

        try
        {
            // The list refresh intentionally pulls from API each time so users see edits made in other clients.
            var payload = await ApiClient.GetBookmarksAsync(CancellationToken.None);
            _allBookmarks.Clear();
            _allBookmarks.AddRange(payload);
            ApplyFilter();
            StatusText = $"Loaded {_allBookmarks.Count} bookmark(s).";
        }
        catch (ApiClientException exception)
        {
            ErrorText = exception.UserMessage;
            StatusText = "Bookmark loading failed.";
        }
        catch (Exception)
        {
            ErrorText = "Could not load bookmarks from API.";
            StatusText = "Bookmark loading failed.";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void SelectCollection(Guid? collectionId)
    {
        var target = collectionId.HasValue
            ? $"/bookmarks?collectionId={collectionId.Value}"
            : "/bookmarks";

        NavigationManager.NavigateTo(target);
    }

    private void SelectOtherCollection()
    {
        NavigationManager.NavigateTo($"/bookmarks?virtualCollection={OtherVirtualCollectionKey}");
    }

    private void ApplyFilter()
    {
        // Collection filter is query-driven so sidebar and page URLs remain shareable.
        IEnumerable<BookmarkDto> candidates;

        if (IsOtherCollectionSelected)
        {
            // Virtual "Other" bucket represents bookmarks not mapped to any collection.
            candidates = _allBookmarks.Where(bookmark => bookmark.CollectionIds.Count == 0);
        }
        else if (SelectedCollectionId.HasValue)
        {
            candidates = _allBookmarks.Where(x => x.CollectionIds.Contains(SelectedCollectionId.Value));
        }
        else
        {
            candidates = _allBookmarks;
        }

        if (string.IsNullOrWhiteSpace(SearchText))
        {
            FilteredBookmarks = candidates
                .OrderByDescending(x => x.UpdatedAtUtc)
                .ToList();
            return;
        }

        var normalized = SearchText.Trim();
        FilteredBookmarks = candidates
            .Where(x =>
                x.Title.Contains(normalized, StringComparison.OrdinalIgnoreCase) ||
                x.Url.Contains(normalized, StringComparison.OrdinalIgnoreCase) ||
                (x.Summary?.Contains(normalized, StringComparison.OrdinalIgnoreCase) ?? false))
            .OrderByDescending(x => x.UpdatedAtUtc)
            .ToList();
    }

    private static string DomainFromUrl(string url)
    {
        if (Uri.TryCreate(url, UriKind.Absolute, out var uri))
        {
            return uri.Host;
        }

        return "unknown-source";
    }

    private static string DomainInitial(string url)
    {
        var domain = DomainFromUrl(url);
        var initial = domain.FirstOrDefault(static character => char.IsLetterOrDigit(character));
        return initial == default ? "?" : char.ToUpperInvariant(initial).ToString();
    }

    private static string BuildBookmarkIconUrl(string url)
    {
        // Browser cache keys are URL-based, so normalize to origin and reuse one icon URL
        // across all bookmarks from the same site.
        var cacheKeyUrl = url;
        if (Uri.TryCreate(url, UriKind.Absolute, out var uri))
        {
            cacheKeyUrl = uri.GetLeftPart(UriPartial.Authority);
        }

        return $"/bookmark-icons?url={Uri.EscapeDataString(cacheKeyUrl)}";
    }

    private async Task OpenEditDialogAsync(BookmarkDto item)
    {
        // Clone selected values into a dedicated edit model so list rendering remains immutable.
        EditingBookmarkId = item.Id;
        EditModel = new UpdateBookmarkRequest
        {
            Title = item.Title,
            Url = item.Url,
            Summary = item.Summary
        };

        OriginalEditModel = new UpdateBookmarkRequest
        {
            Title = item.Title,
            Url = item.Url,
            Summary = item.Summary
        };

        SelectedEditCollectionIds = item.CollectionIds.ToHashSet();

        EditErrorText = null;
        EditMetadataSuggestion = null;
        EditMetadataErrorText = null;
        IsEditMetadataLoading = false;
        IsEditDialogOpen = true;
        await QueueEditMetadataLookupAsync(EditModel.Url);
    }

    private void CloseEditDialog()
    {
        if (IsSavingEdit)
        {
            return;
        }

        IsEditDialogOpen = false;
        EditingBookmarkId = null;
        EditErrorText = null;
        EditMetadataSuggestion = null;
        EditMetadataErrorText = null;
        IsEditMetadataLoading = false;
        LastEditMetadataLookupUrl = string.Empty;
        EditMetadataLookupCts?.Cancel();
        EditMetadataLookupCts?.Dispose();
        EditMetadataLookupCts = null;
        OriginalEditModel = new UpdateBookmarkRequest();
        SelectedEditCollectionIds = [];
    }

    private async Task HandleEditUrlInputAsync(ChangeEventArgs args)
    {
        EditModel.Url = args.Value?.ToString() ?? string.Empty;
        await QueueEditMetadataLookupAsync(EditModel.Url);
    }

    private async Task QueueEditMetadataLookupAsync(string? rawUrl)
    {
        EditMetadataLookupCts?.Cancel();
        EditMetadataLookupCts?.Dispose();

        var normalizedUrl = rawUrl?.Trim() ?? string.Empty;
        if (string.IsNullOrWhiteSpace(normalizedUrl))
        {
            IsEditMetadataLoading = false;
            EditMetadataSuggestion = null;
            EditMetadataErrorText = null;
            LastEditMetadataLookupUrl = string.Empty;
            return;
        }

        // Debounced lookups keep editing smooth while metadata remains close to real-time.
        var currentCts = new CancellationTokenSource();
        EditMetadataLookupCts = currentCts;
        LastEditMetadataLookupUrl = normalizedUrl;
        IsEditMetadataLoading = true;
        EditMetadataErrorText = null;

        try
        {
            await Task.Delay(450, currentCts.Token);

            var requestUrl = new Uri($"{NavigationManager.BaseUri}bookmark-metadata?url={Uri.EscapeDataString(normalizedUrl)}");
            using var client = HttpClientFactory.CreateClient();
            using var response = await client.GetAsync(requestUrl, currentCts.Token);

            if (response.StatusCode == System.Net.HttpStatusCode.NoContent)
            {
                EditMetadataSuggestion = null;
                return;
            }

            response.EnsureSuccessStatusCode();
            var payload = await response.Content.ReadFromJsonAsync<BookmarkMetadataResponse>(cancellationToken: currentCts.Token);
            if (!string.Equals(LastEditMetadataLookupUrl, normalizedUrl, StringComparison.Ordinal))
            {
                return;
            }

            EditMetadataSuggestion = payload is null
                ? null
                : new BookmarkMetadataSuggestion(payload.Title, payload.Description);
        }
        catch (OperationCanceledException) when (currentCts.IsCancellationRequested)
        {
            // New URL input intentionally cancels stale metadata requests.
        }
        catch (Exception)
        {
            EditMetadataSuggestion = null;
            EditMetadataErrorText = "Could not fetch page metadata for this URL.";
        }
        finally
        {
            if (ReferenceEquals(EditMetadataLookupCts, currentCts))
            {
                IsEditMetadataLoading = false;
            }
        }
    }

    private void ApplyEditMetadataSuggestion()
    {
        if (EditMetadataSuggestion is null)
        {
            return;
        }

        // Applying metadata stays user-initiated so manual edits are never overwritten unexpectedly.
        EditModel.Title = EditMetadataSuggestion.Title;
        if (!string.IsNullOrWhiteSpace(EditMetadataSuggestion.Description))
        {
            EditModel.Summary = EditMetadataSuggestion.Description;
        }
    }

    private async Task ApplyEditMetadataSuggestionAndSaveAsync()
    {
        ApplyEditMetadataSuggestion();
        await SaveEditAsync();
    }

    private async Task SaveEditAsync()
    {
        if (EditingBookmarkId is null)
        {
            EditErrorText = "No bookmark selected for edit.";
            return;
        }

        IsSavingEdit = true;
        EditErrorText = null;

        try
        {
            // Refreshing from API after update keeps sidebar counters and filtered ordering consistent.
            await ApiClient.UpdateBookmarkAsync(EditingBookmarkId.Value, EditModel, CancellationToken.None);
            await ApiClient.SyncBookmarkCollectionsAsync(EditingBookmarkId.Value, SelectedEditCollectionIds.ToList(), CancellationToken.None);

            // Reset dialog state immediately after a successful save operation.
            IsEditDialogOpen = false;
            EditingBookmarkId = null;
            EditErrorText = null;
            EditMetadataSuggestion = null;
            EditMetadataErrorText = null;
            IsEditMetadataLoading = false;
            LastEditMetadataLookupUrl = string.Empty;
            EditMetadataLookupCts?.Cancel();
            EditMetadataLookupCts?.Dispose();
            EditMetadataLookupCts = null;
            OriginalEditModel = new UpdateBookmarkRequest();
            SelectedEditCollectionIds = [];

            // Notify sidebar and board components so tree/list views stay consistent.
            SharedStateService.NotifyBookmarksUpdated();
            
            await LoadAsync();
            StateHasChanged();
        }
        catch (ApiClientException exception)
        {
            EditErrorText = exception.UserMessage;
        }
        catch (Exception)
        {
            EditErrorText = "Bookmark update failed.";
        }
        finally
        {
            IsSavingEdit = false;
        }
    }

    private void ToggleEditCollectionSelection(Guid collectionId, object? rawValue)
    {
        var isChecked = rawValue as bool? == true;
        if (isChecked)
        {
            SelectedEditCollectionIds.Add(collectionId);
            return;
        }

        SelectedEditCollectionIds.Remove(collectionId);
    }

    private int CollectionDepth(Guid collectionId)
    {
        var lookup = AvailableCollections.ToDictionary(x => x.Id, x => x.ParentId);
        var depth = 0;
        var current = lookup.TryGetValue(collectionId, out var parentId) ? parentId : null;

        while (current is not null && lookup.TryGetValue(current.Value, out var nextParentId))
        {
            depth++;
            current = nextParentId;
        }

        return depth;
    }

    private sealed record BookmarkMetadataResponse(string Title, string? Description);

    private sealed record BookmarkMetadataSuggestion(string Title, string? Description);
}
