@inject IArcDropApiClient ApiClient
@inject ISharedStateService SharedStateService
@inject NavigationManager NavigationManager
@implements IDisposable

<div class="top-row navbar-brand-shell">
    <div class="container-fluid px-3 d-flex align-items-center gap-2">
        <span class="navbar-brand-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/>
            </svg>
        </span>
        <a class="navbar-brand" href="/bookmarks">ArcDrop</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable">
    <nav class="nav-shell">
        <div class="bookmark-header collection-section__header px-3">
            <p class="nav-section-label">Collections</p>
            <button class="bookmark-refresh" type="button" @onclick="LoadCollectionsSidebarAsync" disabled="@IsBusy">Refresh</button>
        </div>

        @if (IsBusy)
        {
            <div class="px-3 bookmark-state"><span class="spinner-inline"></span> Loading collections...</div>
        }
        else if (!string.IsNullOrWhiteSpace(ErrorText))
        {
            <div class="px-3 bookmark-state bookmark-state--error">@ErrorText</div>
        }
        else if (CollectionTree.Count == 0 && UnassignedBookmarkCount == 0)
        {
            <div class="px-3 bookmark-state">No collections yet.</div>
        }
        else
        {
            <div class="bookmark-list collection-section__list px-2">
                @foreach (var node in GetSidebarCollectionNodes())
                {
                    <CollectionTreeNode @key="node.Id"
                                        Node="node"
                                        Depth="0"
                                        ActiveCollectionId="ActiveCollectionId"
                                        HrefOverride="@(IsOtherCollectionNode(node) ? GetOtherCollectionHref() : null)"
                                        ForceActive="@(IsOtherCollectionNode(node) && IsOtherCollectionActive)" />
                }
            </div>
        }
    </nav>
</div>

@code {
    private const string OtherVirtualCollectionKey = "other";
    private static readonly Guid OtherVirtualCollectionId = Guid.Empty;

    private readonly List<CollectionTreeNodeDto> CollectionTree = [];
    private bool IsBusy { get; set; }
    private string? ErrorText { get; set; }
    private Guid? ActiveCollectionId { get; set; }
    private bool IsOtherCollectionActive { get; set; }
    private int UnassignedBookmarkCount { get; set; }
    private readonly List<BookmarkDto> UnassignedBookmarks = [];

    protected override async Task OnInitializedAsync()
    {
        SharedStateService.OnBookmarksUpdated += HandleBookmarksUpdated;
        SharedStateService.OnCollectionsUpdated += HandleCollectionsUpdated;
        NavigationManager.LocationChanged += HandleLocationChanged;
        ActiveCollectionId = ParseActiveCollectionId();
        IsOtherCollectionActive = ParseOtherCollectionIsActive();
        await LoadCollectionsSidebarAsync();
    }

    private void HandleLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs args)
    {
        ActiveCollectionId = ParseActiveCollectionId();
        IsOtherCollectionActive = ParseOtherCollectionIsActive();
        _ = InvokeAsync(StateHasChanged);
    }

    private async void HandleBookmarksUpdated()
    {
        // Refresh both data sources so the virtual Other collection stays in sync with the tree.
        await InvokeAsync(async () =>
        {
            await LoadCollectionsSidebarAsync();
            StateHasChanged();
        });
    }

    private async void HandleCollectionsUpdated()
    {
        await InvokeAsync(async () =>
        {
            await LoadCollectionsSidebarAsync();
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        SharedStateService.OnBookmarksUpdated -= HandleBookmarksUpdated;
        SharedStateService.OnCollectionsUpdated -= HandleCollectionsUpdated;
        NavigationManager.LocationChanged -= HandleLocationChanged;
    }

    private async Task LoadCollectionsSidebarAsync()
    {
        IsBusy = true;
        ErrorText = null;

        try
        {
            // The sidebar merges persisted collections with the virtual Other collection from uncategorized bookmarks.
            var bookmarks = await ApiClient.GetBookmarksAsync(CancellationToken.None);
            var collections = await ApiClient.GetCollectionsTreeAsync(CancellationToken.None);

            UnassignedBookmarkCount = bookmarks.Count(bookmark => bookmark.CollectionIds.Count == 0);
            UnassignedBookmarks.Clear();
            UnassignedBookmarks.AddRange(bookmarks
                .Where(bookmark => bookmark.CollectionIds.Count == 0)
                .OrderByDescending(bookmark => bookmark.UpdatedAtUtc)
                .Take(40));

            CollectionTree.Clear();
            CollectionTree.AddRange(collections);
        }
        catch (ApiClientException exception)
        {
            ErrorText = exception.UserMessage;
        }
        catch (Exception)
        {
            ErrorText = "Could not load collections.";
        }
        finally
        {
            IsBusy = false;
        }
    }

    private IEnumerable<CollectionTreeNodeDto> GetSidebarCollectionNodes()
    {
        if (UnassignedBookmarks.Count > 0)
        {
            yield return BuildOtherCollectionNode();
        }

        foreach (var node in CollectionTree)
        {
            yield return node;
        }
    }

    private CollectionTreeNodeDto BuildOtherCollectionNode()
    {
        // Represent uncategorized bookmarks as a virtual collection so the sidebar uses one rendering path.
        return new CollectionTreeNodeDto(
            OtherVirtualCollectionId,
            "Other",
            null,
            null,
            DateTimeOffset.MinValue,
            DateTimeOffset.MinValue,
            UnassignedBookmarks
                .Select(bookmark => new CollectionBookmarkItemDto(bookmark.Id, bookmark.Title, bookmark.Url, bookmark.UpdatedAtUtc))
                .ToArray(),
            []);
    }

    private static bool IsOtherCollectionNode(CollectionTreeNodeDto node)
    {
        return node.Id == OtherVirtualCollectionId;
    }

    private static string GetOtherCollectionHref()
    {
        return "/bookmarks?virtualCollection=other";
    }

    private static string DomainFromUrl(string url)
    {
        if (Uri.TryCreate(url, UriKind.Absolute, out var uri))
        {
            return uri.Host;
        }

        return "unknown-source";
    }

    private Guid? ParseActiveCollectionId()
    {
        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        if (!query.TryGetValue("collectionId", out var rawId))
        {
            return null;
        }

        return Guid.TryParse(rawId.ToString(), out var parsedId) ? parsedId : null;
    }

    private bool ParseOtherCollectionIsActive()
    {
        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        return query.TryGetValue("virtualCollection", out var rawVirtualCollection)
            && string.Equals(rawVirtualCollection.ToString(), OtherVirtualCollectionKey, StringComparison.OrdinalIgnoreCase);
    }
}

