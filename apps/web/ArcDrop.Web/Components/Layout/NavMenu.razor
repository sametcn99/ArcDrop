@inject IArcDropApiClient ApiClient
@inject ISharedStateService SharedStateService
@inject NavigationManager NavigationManager
@implements IDisposable

<div class="top-row navbar-brand-shell">
    <div class="container-fluid px-3 d-flex align-items-center gap-2">
        <span class="navbar-brand-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/>
            </svg>
        </span>
        <a class="navbar-brand" href="/bookmarks">ArcDrop</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable">
    <nav class="nav-shell">
        <div class="bookmark-header px-3">
            <p class="nav-section-label">Bookmarks</p>
            <button class="bookmark-refresh" type="button" @onclick="LoadBookmarksAsync" disabled="@IsBusy">Refresh</button>
        </div>

        @if (IsBusy)
        {
            <div class="px-3 bookmark-state"><span class="spinner-inline"></span> Loading bookmarks...</div>
        }
        else if (!string.IsNullOrWhiteSpace(ErrorText))
        {
            <div class="px-3 bookmark-state bookmark-state--error">@ErrorText</div>
        }
        else if (Bookmarks.Count == 0)
        {
            <div class="px-3 bookmark-state">No bookmarks yet.</div>
        }
        else
        {
            <div class="bookmark-list px-2">
                <div class="bookmark-root-row">
                    <NavLink class="bookmark-link bookmark-link--all" href="/bookmarks" Match="NavLinkMatch.Prefix">All Bookmarks</NavLink>
                    <button class="sidebar-collapse-toggle"
                            type="button"
                            aria-label="Toggle all bookmarks"
                            aria-expanded="@IsBookmarksExpanded"
                            @onclick="ToggleBookmarksExpanded">
                        <span class="sidebar-collapse-icon @(IsBookmarksExpanded ? "is-expanded" : string.Empty)"></span>
                    </button>
                </div>

                @if (IsBookmarksExpanded)
                {
                    @foreach (var bookmark in Bookmarks)
                    {
                        @* Sidebar bookmark entries should open the original bookmark URL in a new browser tab. *@
                        <a class="bookmark-link" href="@bookmark.Url" target="_blank" rel="noopener noreferrer">
                            <span class="bookmark-link__title">@bookmark.Title</span>
                            <span class="bookmark-link__meta">@DomainFromUrl(bookmark.Url)</span>
                        </a>
                    }
                }
            </div>
        }

        <div class="bookmark-header collection-section__header px-3">
            <p class="nav-section-label">Collections</p>
            <button class="bookmark-refresh" type="button" @onclick="LoadCollectionTreeAsync" disabled="@IsBusy">Refresh</button>
        </div>

        @if (IsBusy)
        {
            <div class="px-3 bookmark-state"><span class="spinner-inline"></span> Loading collections...</div>
        }
        else if (CollectionTree.Count == 0)
        {
            <div class="px-3 bookmark-state">No collections yet.</div>
        }
        else
        {
            <div class="bookmark-list collection-section__list px-2">
                @foreach (var node in CollectionTree)
                {
                    <CollectionTreeNode Node="node" Depth="0" ActiveCollectionId="ActiveCollectionId" />
                }
            </div>
        }
    </nav>
</div>

@code {
    private readonly List<BookmarkDto> Bookmarks = [];
    private readonly List<CollectionTreeNodeDto> CollectionTree = [];
    private bool IsBusy { get; set; }
    private bool IsUserMenuOpen { get; set; }
    private bool IsBookmarksExpanded { get; set; } = true;
    private string? ErrorText { get; set; }
    private Guid? ActiveCollectionId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        SharedStateService.OnBookmarksUpdated += HandleBookmarksUpdated;
        SharedStateService.OnCollectionsUpdated += HandleCollectionsUpdated;
        NavigationManager.LocationChanged += HandleLocationChanged;
        ActiveCollectionId = ParseActiveCollectionId();
        await LoadBookmarksAsync();
        await LoadCollectionTreeAsync();
    }

    private void HandleLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs args)
    {
        ActiveCollectionId = ParseActiveCollectionId();
        _ = InvokeAsync(StateHasChanged);
    }

    private async void HandleBookmarksUpdated()
    {
        // Use InvokeAsync to ensure UI updates on the correct thread
        await InvokeAsync(async () =>
        {
            await LoadBookmarksAsync();
            await LoadCollectionTreeAsync();
            StateHasChanged();
        });
    }

    private async void HandleCollectionsUpdated()
    {
        await InvokeAsync(async () =>
        {
            await LoadCollectionTreeAsync();
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        SharedStateService.OnBookmarksUpdated -= HandleBookmarksUpdated;
        SharedStateService.OnCollectionsUpdated -= HandleCollectionsUpdated;
        NavigationManager.LocationChanged -= HandleLocationChanged;
    }

    private void ToggleUserMenu()
    {
        IsUserMenuOpen = !IsUserMenuOpen;
    }

    private void ToggleBookmarksExpanded()
    {
        IsBookmarksExpanded = !IsBookmarksExpanded;
    }

    private async Task LoadBookmarksAsync()
    {
        IsBusy = true;
        ErrorText = null;

        try
        {
            // Sidebar ordering is deterministic so users can quickly scan recently updated entries.
            var payload = await ApiClient.GetBookmarksAsync(CancellationToken.None);
            Bookmarks.Clear();
            Bookmarks.AddRange(payload.OrderByDescending(x => x.UpdatedAtUtc).Take(60));
        }
        catch (ApiClientException exception)
        {
            ErrorText = exception.UserMessage;
        }
        catch (Exception)
        {
            ErrorText = "Could not load bookmarks.";
        }
        finally
        {
            IsBusy = false;
        }
    }

    private async Task LoadCollectionTreeAsync()
    {
        IsBusy = true;
        ErrorText = null;

        try
        {
            var payload = await ApiClient.GetCollectionsTreeAsync(CancellationToken.None);
            CollectionTree.Clear();
            CollectionTree.AddRange(payload);
        }
        catch (ApiClientException exception)
        {
            ErrorText = exception.UserMessage;
        }
        catch (Exception)
        {
            ErrorText = "Could not load collections.";
        }
        finally
        {
            IsBusy = false;
        }
    }

    private static string DomainFromUrl(string url)
    {
        if (Uri.TryCreate(url, UriKind.Absolute, out var uri))
        {
            return uri.Host;
        }

        return "unknown-source";
    }

    private static string UserInitial(string? name)
    {
        if (string.IsNullOrWhiteSpace(name))
        {
            return "A";
        }

        return name.Trim()[0].ToString().ToUpperInvariant();
    }

    private Guid? ParseActiveCollectionId()
    {
        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        if (!query.TryGetValue("collectionId", out var rawId))
        {
            return null;
        }

        return Guid.TryParse(rawId.ToString(), out var parsedId) ? parsedId : null;
    }
}

