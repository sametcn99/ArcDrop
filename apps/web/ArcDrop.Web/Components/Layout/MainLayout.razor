@inherits LayoutComponentBase
@inject IArcDropApiClient ApiClient
@inject NavigationManager NavigationManager
@inject ISharedStateService SharedStateService
@implements IDisposable

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <div class="top-row-context">
                <AuthorizeView>
                    <Authorized>
                        <span class="arc-badge arc-badge--success">Authenticated</span>
                    </Authorized>
                    <NotAuthorized>
                        <span class="arc-badge arc-badge--muted">Anonymous</span>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
            <div class="top-row-actions">
                <AuthorizeView>
                    <Authorized Context="authContext">
                        <button class="btn btn-primary btn-sm" type="button" @onclick="OpenCreateDialog">
                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: -2px; margin-right: 4px;"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                            Add Bookmark
                        </button>
                        <button class="btn btn-outline-secondary btn-sm" type="button" @onclick="OpenCreateCollectionDialog" style="margin-left:0.45rem;">
                            New Collection
                        </button>
                        <a class="top-row-profile" href="/settings#account">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: -2px; margin-right: 4px;"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>@(authContext.User.Identity?.Name ?? "Admin")
                        </a>
                    </Authorized>
                    <NotAuthorized>
                        <a href="/auth/login">Sign In</a>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@if (IsCreateDialogOpen)
{
    <div class="arc-modal-backdrop" @onclick="CloseCreateDialog"></div>
    <section class="arc-modal" role="dialog" aria-modal="true" aria-labelledby="create-bookmark-title">
        <header class="arc-modal__header">
            <div>
                <h2 id="create-bookmark-title">Add Bookmark</h2>
                <p class="page-subtitle">Create a new bookmark without leaving the current page.</p>
            </div>
            <button class="arc-modal__close" type="button" @onclick="CloseCreateDialog" aria-label="Close">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </header>

        <EditForm Model="CreateModel" OnValidSubmit="CreateBookmarkAsync">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="mb-3">
                <label class="form-label">Title</label>
                <InputText class="form-control" @bind-Value="CreateModel.Title" placeholder="Bookmark title" />
            </div>

            <div class="mb-3">
                <label class="form-label">URL</label>
                <InputText class="form-control" @bind-Value="CreateModel.Url" placeholder="https://example.com" />
            </div>

            <div class="mb-3">
                <label class="form-label">Summary</label>
                <InputTextArea class="form-control" @bind-Value="CreateModel.Summary" rows="3" placeholder="Optional summary or note" />
            </div>

            <div class="mb-3">
                <label class="form-label">Collections</label>
                @if (AvailableCollections.Count == 0)
                {
                    <div class="form-text">No collections available yet.</div>
                }
                else
                {
                    <div style="max-height: 180px; overflow-y: auto; border: 1px solid var(--arc-border-light); border-radius: 8px; padding: 0.5rem;">
                        @foreach (var collection in AvailableCollections)
                        {
                            <label class="d-flex align-items-center gap-2" style="padding: 0.15rem 0; margin-left:@(CollectionDepth(collection.Id) * 0.7)rem;">
                                <input type="checkbox"
                                       checked="@SelectedCollectionIds.Contains(collection.Id)"
                                       @onchange="(args => ToggleCreateCollectionSelection(collection.Id, args.Value))" />
                                <span>@collection.Name</span>
                            </label>
                        }
                    </div>
                }
            </div>

            @if (!string.IsNullOrWhiteSpace(CreateErrorText))
            {
                <div class="alert alert-danger" role="alert">@CreateErrorText</div>
            }

            <footer class="arc-modal__footer">
                <button class="btn btn-outline-secondary" type="button" @onclick="CloseCreateDialog" disabled="@IsCreating">Cancel</button>
                <button class="btn btn-primary" type="submit" disabled="@IsCreating">
                    @if (IsCreating) { <span class="spinner-inline"></span> }
                    Save Bookmark
                </button>
            </footer>
        </EditForm>
    </section>
}

@if (IsCreateCollectionDialogOpen)
{
    <div class="arc-modal-backdrop" @onclick="CloseCreateCollectionDialog"></div>
    <section class="arc-modal" role="dialog" aria-modal="true" aria-labelledby="create-collection-title">
        <header class="arc-modal__header">
            <div>
                <h2 id="create-collection-title">New Collection</h2>
                <p class="page-subtitle">Create nested collection folders for tree-based organization.</p>
            </div>
            <button class="arc-modal__close" type="button" @onclick="CloseCreateCollectionDialog" aria-label="Close">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </header>

        <EditForm Model="CreateCollectionModel" OnValidSubmit="CreateCollectionAsync">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="mb-3">
                <label class="form-label">Name</label>
                <InputText class="form-control" @bind-Value="CreateCollectionModel.Name" placeholder="Collection name" />
            </div>

            <div class="mb-3">
                <label class="form-label">Description</label>
                <InputTextArea class="form-control" @bind-Value="CreateCollectionModel.Description" rows="2" placeholder="Optional description" />
            </div>

            <div class="mb-3">
                <label class="form-label">Parent Collection</label>
                <InputSelect class="form-select" @bind-Value="CreateCollectionModel.ParentId">
                    <option value="">Root</option>
                    @foreach (var collection in AvailableCollections)
                    {
                        <option value="@collection.Id">@collection.Name</option>
                    }
                </InputSelect>
            </div>

            @if (!string.IsNullOrWhiteSpace(CreateCollectionErrorText))
            {
                <div class="alert alert-danger" role="alert">@CreateCollectionErrorText</div>
            }

            <footer class="arc-modal__footer">
                <button class="btn btn-outline-secondary" type="button" @onclick="CloseCreateCollectionDialog" disabled="@IsCreatingCollection">Cancel</button>
                <button class="btn btn-primary" type="submit" disabled="@IsCreatingCollection">
                    @if (IsCreatingCollection) { <span class="spinner-inline"></span> }
                    Save Collection
                </button>
            </footer>
        </EditForm>
    </section>
}

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private CreateBookmarkRequest CreateModel { get; set; } = new();
    private IReadOnlyList<CollectionDto> AvailableCollections { get; set; } = [];
    private HashSet<Guid> SelectedCollectionIds { get; set; } = [];
    private CreateCollectionRequest CreateCollectionModel { get; set; } = new();
    private bool IsCreateDialogOpen { get; set; }
    private bool IsCreateCollectionDialogOpen { get; set; }
    private bool IsCreating { get; set; }
    private bool IsCreatingCollection { get; set; }
    private string? CreateErrorText { get; set; }
    private string? CreateCollectionErrorText { get; set; }

    protected override async Task OnInitializedAsync()
    {
        SharedStateService.OnCollectionsUpdated += HandleCollectionsUpdated;
        await LoadCollectionsAsync();
    }

    private async void HandleCollectionsUpdated()
    {
        await InvokeAsync(async () =>
        {
            await LoadCollectionsAsync();
            StateHasChanged();
        });
    }

    private void OpenCreateDialog()
    {
        CreateErrorText = null;
        CreateModel = new CreateBookmarkRequest();
        SelectedCollectionIds = [];
        IsCreateDialogOpen = true;
    }

    private void CloseCreateDialog()
    {
        if (IsCreating)
        {
            return;
        }

        IsCreateDialogOpen = false;
    }

    private void OpenCreateCollectionDialog()
    {
        CreateCollectionErrorText = null;
        CreateCollectionModel = new CreateCollectionRequest();
        IsCreateCollectionDialogOpen = true;
    }

    private void CloseCreateCollectionDialog()
    {
        if (IsCreatingCollection)
        {
            return;
        }

        IsCreateCollectionDialogOpen = false;
    }

    private async Task CreateBookmarkAsync()
    {
        IsCreating = true;
        CreateErrorText = null;

        try
        {
            // Create the bookmark first, then synchronize collection memberships.
            var created = await ApiClient.CreateBookmarkAsync(CreateModel, CancellationToken.None);
            await ApiClient.SyncBookmarkCollectionsAsync(created.Id, SelectedCollectionIds.ToList(), CancellationToken.None);
            
            // Close dialog immediately
            IsCreateDialogOpen = false;
            
            // Notify other components to refresh (NavMenu and Bookmarks page)
            SharedStateService.NotifyBookmarksUpdated();
        }
        catch (ApiClientException exception)
        {
            CreateErrorText = exception.UserMessage;
        }
        catch (Exception)
        {
            CreateErrorText = "Bookmark creation failed.";
        }
        finally
        {
            IsCreating = false;
        }
    }

    private async Task CreateCollectionAsync()
    {
        IsCreatingCollection = true;
        CreateCollectionErrorText = null;

        try
        {
            await ApiClient.CreateCollectionAsync(CreateCollectionModel, CancellationToken.None);
            IsCreateCollectionDialogOpen = false;
            await LoadCollectionsAsync();
            SharedStateService.NotifyCollectionsUpdated();
        }
        catch (ApiClientException exception)
        {
            CreateCollectionErrorText = exception.UserMessage;
        }
        catch (Exception)
        {
            CreateCollectionErrorText = "Collection creation failed.";
        }
        finally
        {
            IsCreatingCollection = false;
        }
    }

    private async Task LoadCollectionsAsync()
    {
        try
        {
            AvailableCollections = await ApiClient.GetCollectionsAsync(CancellationToken.None);
        }
        catch
        {
            AvailableCollections = [];
        }
    }

    private void ToggleCreateCollectionSelection(Guid collectionId, object? rawValue)
    {
        var isChecked = rawValue as bool? == true;
        if (isChecked)
        {
            SelectedCollectionIds.Add(collectionId);
            return;
        }

        SelectedCollectionIds.Remove(collectionId);
    }

    private int CollectionDepth(Guid collectionId)
    {
        var lookup = AvailableCollections.ToDictionary(x => x.Id, x => x.ParentId);
        var depth = 0;
        var current = lookup.TryGetValue(collectionId, out var parentId) ? parentId : null;

        while (current is not null && lookup.TryGetValue(current.Value, out var nextParentId))
        {
            depth++;
            current = nextParentId;
        }

        return depth;
    }

    public void Dispose()
    {
        SharedStateService.OnCollectionsUpdated -= HandleCollectionsUpdated;
    }
}
