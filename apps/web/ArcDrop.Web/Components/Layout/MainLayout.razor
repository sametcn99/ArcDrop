@inherits LayoutComponentBase
@inject IArcDropApiClient ApiClient
@inject NavigationManager NavigationManager

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <div class="top-row-context">
                <AuthorizeView>
                    <Authorized>
                        <span class="arc-badge arc-badge--success">Authenticated</span>
                    </Authorized>
                    <NotAuthorized>
                        <span class="arc-badge arc-badge--muted">Anonymous</span>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
            <div class="top-row-actions">
                <AuthorizeView>
                    <Authorized Context="authContext">
                        <button class="btn btn-primary btn-sm" type="button" @onclick="OpenCreateDialog">
                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: -2px; margin-right: 4px;"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                            Add Bookmark
                        </button>
                        <a class="top-row-profile" href="/settings#account">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: -2px; margin-right: 4px;"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>@(authContext.User.Identity?.Name ?? "Admin")
                        </a>
                    </Authorized>
                    <NotAuthorized>
                        <a href="/auth/login">Sign In</a>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@if (IsCreateDialogOpen)
{
    <div class="arc-modal-backdrop" @onclick="CloseCreateDialog"></div>
    <section class="arc-modal" role="dialog" aria-modal="true" aria-labelledby="create-bookmark-title">
        <header class="arc-modal__header">
            <div>
                <h2 id="create-bookmark-title">Add Bookmark</h2>
                <p class="page-subtitle">Create a new bookmark without leaving the current page.</p>
            </div>
            <button class="arc-modal__close" type="button" @onclick="CloseCreateDialog" aria-label="Close">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </header>

        <EditForm Model="CreateModel" OnValidSubmit="CreateBookmarkAsync">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="mb-3">
                <label class="form-label">Title</label>
                <InputText class="form-control" @bind-Value="CreateModel.Title" placeholder="Bookmark title" />
            </div>

            <div class="mb-3">
                <label class="form-label">URL</label>
                <InputText class="form-control" @bind-Value="CreateModel.Url" placeholder="https://example.com" />
            </div>

            <div class="mb-3">
                <label class="form-label">Summary</label>
                <InputTextArea class="form-control" @bind-Value="CreateModel.Summary" rows="3" placeholder="Optional summary or note" />
            </div>

            @if (!string.IsNullOrWhiteSpace(CreateErrorText))
            {
                <div class="alert alert-danger" role="alert">@CreateErrorText</div>
            }

            <footer class="arc-modal__footer">
                <button class="btn btn-outline-secondary" type="button" @onclick="CloseCreateDialog" disabled="@IsCreating">Cancel</button>
                <button class="btn btn-primary" type="submit" disabled="@IsCreating">
                    @if (IsCreating) { <span class="spinner-inline"></span> }
                    Save Bookmark
                </button>
            </footer>
        </EditForm>
    </section>
}

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private CreateBookmarkRequest CreateModel { get; set; } = new();
    private bool IsCreateDialogOpen { get; set; }
    private bool IsCreating { get; set; }
    private string? CreateErrorText { get; set; }

    private void OpenCreateDialog()
    {
        CreateErrorText = null;
        CreateModel = new CreateBookmarkRequest();
        IsCreateDialogOpen = true;
    }

    private void CloseCreateDialog()
    {
        if (IsCreating)
        {
            return;
        }

        IsCreateDialogOpen = false;
    }

    private async Task CreateBookmarkAsync()
    {
        IsCreating = true;
        CreateErrorText = null;

        try
        {
            // Dialog create keeps user in the current shell while still routing to the created resource.
            var created = await ApiClient.CreateBookmarkAsync(CreateModel, CancellationToken.None);
            IsCreateDialogOpen = false;
            NavigationManager.NavigateTo($"/bookmarks/{created.Id}");
        }
        catch (ApiClientException exception)
        {
            CreateErrorText = exception.UserMessage;
        }
        catch (Exception)
        {
            CreateErrorText = "Bookmark creation failed.";
        }
        finally
        {
            IsCreating = false;
        }
    }
}
