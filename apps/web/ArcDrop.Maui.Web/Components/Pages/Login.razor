@page "/auth/login"
@rendermode InteractiveServer

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager Navigation

<PageTitle>Admin Login</PageTitle>

<div class="auth-card-wrapper">
    <div class="auth-card">
        <div class="auth-brand">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="var(--arc-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
            <h1>ArcDrop</h1>
            <p>Sign in to access your workspace</p>
        </div>

        <div class="card-shell">
            <form method="post" action="/auth/session/login">
                <AntiforgeryToken />
                <div class="mb-3">
                    <label class="form-label">Username</label>
                    <input class="form-control" name="Username" autocomplete="username" placeholder="Enter username" required />
                </div>

                <div class="mb-3">
                    <label class="form-label">Password</label>
                    <input class="form-control" name="Password" type="password" autocomplete="current-password" placeholder="Enter password" required />
                </div>

                <input type="hidden" name="returnUrl" value="@ResolvedReturnUrl" />

                @if (!string.IsNullOrWhiteSpace(ErrorText))
                {
                    <div class="alert alert-danger mb-3" role="alert">@ErrorText</div>
                }

                <button class="btn btn-primary w-100" type="submit">Sign In</button>
            </form>
        </div>

        @if (!string.IsNullOrWhiteSpace(StatusText))
        {
            <p class="status-hint mt-3" style="justify-content: center;">@StatusText</p>
        }
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery(Name = "error")]
    public string? ErrorCode { get; set; }

    private string StatusText { get; set; } = "Use fixed-admin credentials to access protected API operations.";
    private string? ErrorText { get; set; }
    private string ResolvedReturnUrl { get; set; } = "/bookmarks";

    protected override async Task OnParametersSetAsync()
    {
        ResolvedReturnUrl = AuthRoutePolicy.ResolveSafeReturnUrl(ReturnUrl);
        ErrorText = MapError(ErrorCode);

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated is true)
        {
            Navigation.NavigateTo(ResolvedReturnUrl, replace: true);
            return;
        }

        StatusText = string.IsNullOrWhiteSpace(ErrorText)
            ? "Use fixed-admin credentials to access protected API operations."
            : "Sign-in did not complete.";
    }

    private static string? MapError(string? errorCode)
        => errorCode switch
        {
            "missing_credentials" => "Username and password are required.",
            "invalid_credentials" => "Authentication failed. Verify username and password.",
            "auth_service_error" => "Authentication service is unavailable. Try again shortly.",
            "invalid_auth_payload" => "Authentication response was invalid. Sign in again.",
            _ => null
        };
}
